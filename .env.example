FRONTEND_PORT= Your frontend port (default: 5000)
BACKEND_PORT= Your backend port (default: 7000)

VITE_API_BASE= The base URL for API requests from the frontend (e.g., http://localhost:7000/api)

# Database configuration
MONGO_URI= Your MongoDB connection string (e.g., mongodb://localhost:27017/primetrade)

JWT_SECRET= Your JWT secret key (use a strong random string)